# ============================================================
# Chronobreak — .gitignore
# 代码作品集配置：只追踪代码+场景+配置，忽略所有大文件资源
# ============================================================

# ==================== Unity 系统目录 ====================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/

# ==================== 大文件资源 & 配套 .meta ====================
# 作品集只跟踪代码（.cs）和文本配置，所有二进制资源全忽略

# 图片
*.png
*.png.meta
*.jpg
*.jpg.meta
*.jpeg
*.jpeg.meta
*.gif
*.gif.meta
*.bmp
*.bmp.meta
*.tga
*.tga.meta
*.tif
*.tiff
*.tif.meta
*.tiff.meta
*.psd
*.psd.meta
*.psb
*.psb.meta
*.exr
*.exr.meta
*.hdr
*.hdr.meta
*.ico
*.ico.meta
*.svg
*.svg.meta

# 3D 模型
*.fbx
*.fbx.meta
*.obj
*.obj.meta
*.blend
*.blend.meta
*.dae
*.dae.meta
*.3ds
*.3ds.meta
*.max
*.max.meta
*.ma
*.ma.meta
*.mb
*.mb.meta
*.c4d
*.c4d.meta

