*.flv.meta

# 字体
*.ttf
*.ttf.meta
*.otf
*.otf.meta
*.fon
*.fon.meta

# 材质贴图压缩格式
*.dds
*.dds.meta
*.pvr
*.pvr.meta
*.ktx
*.ktx.meta

# ==================== 编译产物 / 可执行文件 ====================
*.exe
*.exe.meta
*.dll
*.dll.meta
*.pdb
*.pdb.meta
*.so
*.so.meta
*.dylib
*.dylib.meta
*.bundle
*.bundle.meta
*.apk
*.apk.meta
*.aab
*.aab.meta
*.ipa
*.ipa.meta

# ==================== IDE / 编辑器设置 ====================
.vscode/
.idea/
*.csproj
*.csproj.meta
*.sln
*.user
*.userosscache
*.suo
*.sln.docstates

# .slnx 保留（Unity 6 使用，但如果你用 VS/VSCode 打开会生成）
# 如果不需要可以取消注释下一行：
# *.slnx

# ==================== 操作系统文件 ====================
.DS_Store
Thumbs.db
Desktop.ini

# ==================== 日志 / 崩溃转储 ====================
*.log
*.crashdump
*.dmp
